# Server Configuration (Production)
PORT=80
NODE_ENV=production

# Database Configuration (Provide actual production DB info)
DB_HOST=your_prod_db_host
DB_PORT=3306
DB_USERNAME=your_prod_db_user
DB_PASSWORD=your_secure_password
DB_DATABASE=movie_diary_prod

# Security
# MUST change this to a long, random string in production
JWT_SECRET=your_long_random_production_secret_key
# Set to your actual domain(s)
ALLOWED_ORIGINS=https://your-domain.com

# Throttler (More strict in production)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
