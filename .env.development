# ----------------------------------------------------------------------
# 서버 상태 설정
# ----------------------------------------------------------------------
# 앱이 실행될 포트 (지정하지 않으면 3000번 포트 기본 사용)
PORT=3000

# 앱 실행 모드 (development, production 등)
NODE_ENV=development

# ----------------------------------------------------------------------
# 데이터베이스 (MySQL) 설정
# ----------------------------------------------------------------------
# MySQL이 실행 중인 호스트 (로컬이면 localhost)
DB_HOST=localhost

# MySQL 기본 접속 포트 (기본 3306)
DB_PORT=3306

# MySQL 사용자 이름 (보통 root 또는 별도 생성한 계정명)
DB_USERNAME=root

# MySQL 비밀번호 (본인이 설정한 비밀번호)
DB_PASSWORD=dogbook7!

# 사용할 데이터베이스 및 테이블 이름 
# (MySQL에 접속해서 미리 이 이름으로 CREATE DATABASE 를 해두셔야 합니다)
DB_DATABASE='movie_diary'

# ----------------------------------------------------------------------
# JWT 인증 토큰 시크릿
# ----------------------------------------------------------------------
# 임의의 복잡한 문자열 사용 권장 (예: 사용자 기기 해킹 방지용)
JWT_SECRET=test_jwt_secret

# ----------------------------------------------------------------------
# 한국영상자료원(KMDB) 영화 검색 API 설정
# ----------------------------------------------------------------------
# KMDB에서 발급받은 오픈 API 키 (필수)
KMDB_API_KEY=5Y4M505857WAT5XLSWEQ

# KMDB 검색 API 엔드포인트 기본 주소
KMDB_API_URL=http://api.koreafilm.or.kr/openapi-data2/wisenut/search_api/search_json2.jsp